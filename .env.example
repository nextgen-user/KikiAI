# =============================================================================
# Kiki Voice Assistant — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.

# Required keys are marked with [REQUIRED].
# Optional keys are marked with [OPTIONAL] — features will be disabled if missing.
# =============================================================================

# --- Speech-to-Text (Deepgram) [REQUIRED] ---
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# --- LLM Provider (Gemini) [REQUIRED — at least one] ---
GEMINI_API_KEY="" #IF VERTEX AI (GOOGLE_APPLICATION_CREDENTIALS) IS NOT USED (for responses) (Update model config in config.json too.)
# JSON array of Gemini API keys (for key rotation / fallback)
GEMINI_KEY_LIST=["your_gemini_key_1","your_gemini_key_2"] #(FOR DEEP THINKING)

# --- LLM Provider (Groq) [OPTIONAL — used as fallback] ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_LIST=["your_groq_key_1","your_groq_key_2"]

# --- Text-to-Speech [REQUIRED — at least one provider] ---
# Groq TTS (default provider)
# Uses the same GROQ_API_KEY above

# Inworld TTS (alternative provider, set tts.provider to "inworld" in config.json)
INWORLD_API_KEY=your_inworld_api_key_here

# --- Vertex AI (Prferred over aistudio) [OPTIONAL — only if using vertex_ai/ models] --- 

# Option 1: Set path to your Google Cloud credentials JSON file
GOOGLE_APPLICATION_CREDENTIALS
# Option 2: Paste the full JSON as a string
# VERTEX_CREDENTIALS_JSON={"type":"service_account",...}

# --- Hotword Detection (Picovoice Porcupine) [REQUIRED for wake word] ---
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here

# --- Web Search (Exa) [OPTIONAL — enables search_web tool] ---
EXA_API_KEY=your_exa_api_key_here

# --- OTHERS ---
# OpenAI-compatible key (only if using OpenAI models)
OPENAI_API_KEY=your_openai_api_key_here

